default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # On CI: create a fresh unlocked keychain so the .p12 private key can be
    # imported. Using create_keychain instead of setup_ci gives us an explicit
    # unlock + add_to_search_list, which avoids "SecItemCopyMatching: item not
    # found" when match tries to set the key partition list after import.
    if is_ci
      create_keychain(
        name: "fastlane_tmp_keychain",
        password: "",
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        add_to_search_list: true,
      )
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    # Sync certificates & provisioning profiles from private certs repo.
    match(
      type: "appstore",
      readonly: false,
      api_key: api_key,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: Base64.strict_encode64(
        "#{ENV["MATCH_GIT_USER"]}:#{ENV["MATCH_GIT_TOKEN"]}"
      ),
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: "",
    )

    # Build the IPA
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.gravity.gravityGame" => "match AppStore com.gravity.gravityGame",
        },
      },
    )

    # Upload to TestFlight (don't wait for processing — saves CI minutes)
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end

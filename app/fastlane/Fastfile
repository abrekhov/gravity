require 'fileutils'

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    if is_ci
      # -------------------------------------------------------------------
      # Step 1: Create a fresh, unlocked signing keychain.
      # -------------------------------------------------------------------
      create_keychain(
        name: "fastlane_tmp_keychain",
        password: "",
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        add_to_search_list: true,
      )

      # -------------------------------------------------------------------
      # Step 2: Clone the match certs repo and decrypt+import manually.
      # match's built-in `security import` silently drops the private key
      # on some CI runners. We use match's own Ruby encryption class to
      # decrypt in-place, then import with import_certificate.
      # -------------------------------------------------------------------
      match_user     = ENV["MATCH_GIT_USER"]
      match_token    = ENV["MATCH_GIT_TOKEN"]
      match_password = ENV["MATCH_PASSWORD"]

      certs_dir = Dir.mktmpdir("match_certs")
      sh("git clone 'https://#{match_user}:#{match_token}@github.com/abrekhov/gravity-certificates.git' '#{certs_dir}' --depth 1")

      # Decrypt .p12 using match's own encryption library.
      # decrypt() is in-place: copy first, then decrypt the copy.
      require 'match'
      enc = Match::Encryption::MatchFileEncryption.new

      encrypted_p12 = Dir.glob("#{certs_dir}/certs/distribution/*.p12").first
      UI.user_error!("No .p12 found in certs repo") unless encrypted_p12

      decrypted_p12 = "#{certs_dir}/cert.p12"
      FileUtils.cp(encrypted_p12, decrypted_p12)
      enc.decrypt(file_path: decrypted_p12, password: match_password)
      UI.message("Decrypted .p12 size: #{File.size(decrypted_p12)} bytes")

      import_certificate(
        certificate_path:     decrypted_p12,
        certificate_password: match_password,
        keychain_name:        "fastlane_tmp_keychain",
        keychain_password:    "",
      )

      # Grant codesign access to all private keys in the keychain.
      # Without this the key exists but isn't accessible for signing.
      sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '' ~/Library/Keychains/fastlane_tmp_keychain-db 2>&1 || true")
      sh("echo '-- Identities in signing keychain:' && security find-identity -v -p codesigning ~/Library/Keychains/fastlane_tmp_keychain-db 2>&1 || true")

      # Decrypt and install the provisioning profile.
      encrypted_pp = Dir.glob("#{certs_dir}/profiles/appstore/*.mobileprovision").first
      if encrypted_pp
        pp_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
        FileUtils.mkdir_p(pp_dir)
        decrypted_pp = "#{certs_dir}/profile.mobileprovision"
        FileUtils.cp(encrypted_pp, decrypted_pp)
        enc.decrypt(file_path: decrypted_pp, password: match_password)
        FileUtils.cp(decrypted_pp, "#{pp_dir}/AppStore_com.gravity.gravityGame.mobileprovision")
        UI.message("Installed provisioning profile (#{File.size(decrypted_pp)} bytes)")
      end

      # -------------------------------------------------------------------
      # Step 3: Switch Runner target from Automatic to Manual signing.
      # Using update_code_signing_settings scopes the change to the Runner
      # target only — CocoaPods targets are left as Automatic.
      # -------------------------------------------------------------------
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id:               "D24ZU8268L",
        code_sign_identity:    "Apple Distribution",
        bundle_identifier:     "com.gravity.gravityGame",
        targets:               ["Runner"],
        path:                  "ios/Runner.xcodeproj",
        profile_name:          "match AppStore com.gravity.gravityGame",
      )
    end

    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    # Build the IPA.
    build_app(
      workspace:     "ios/Runner.xcworkspace",
      scheme:        "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.gravity.gravityGame" => "match AppStore com.gravity.gravityGame",
        },
      },
    )

    # Upload to TestFlight (skip waiting — saves CI minutes).
    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end

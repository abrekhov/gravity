require 'fileutils'

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    profile_name = "match AppStore com.gravity.gravityGame"

    if is_ci
      match_user     = ENV["MATCH_GIT_USER"]
      match_token    = ENV["MATCH_GIT_TOKEN"]
      match_password = ENV["MATCH_PASSWORD"]
      keychain_name  = "fastlane_tmp_keychain"
      keychain_db    = File.expand_path("~/Library/Keychains/#{keychain_name}-db")

      create_keychain(
        name: keychain_name,
        password: "",
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        add_to_search_list: true,
      )

      # --- Step 1: Try to import cert+key from the match certs repo. ---
      require 'match'
      enc = Match::Encryption::MatchFileEncryption.new

      certs_dir = Dir.mktmpdir("match_certs")
      sh("git clone 'https://#{match_user}:#{match_token}@github.com/abrekhov/gravity-certificates.git' '#{certs_dir}' --depth 1 2>&1")

      identity_found = false
      encrypted_p12  = Dir.glob("#{certs_dir}/certs/distribution/*.p12").first
      encrypted_cer  = Dir.glob("#{certs_dir}/certs/distribution/*.cer").first

      if encrypted_p12
        decrypted_p12 = "#{certs_dir}/cert.p12"
        FileUtils.cp(encrypted_p12, decrypted_p12)
        enc.decrypt(file_path: decrypted_p12, password: match_password)
        UI.message("Decrypted .p12 size: #{File.size(decrypted_p12)} bytes")
        sh("security import #{decrypted_p12.shellescape} -k #{keychain_db.shellescape} -P #{match_password.to_s.shellescape} -A -T /usr/bin/codesign -T /usr/bin/security 2>&1 || true")
      end

      # Also import the .cer — the p12 may contain only the private key,
      # while the certificate lives in the separate .cer file.
      if encrypted_cer
        decrypted_cer = "#{certs_dir}/cert.cer"
        FileUtils.cp(encrypted_cer, decrypted_cer)
        enc.decrypt(file_path: decrypted_cer, password: match_password)
        UI.message("Decrypted .cer size: #{File.size(decrypted_cer)} bytes")
        sh("security import #{decrypted_cer.shellescape} -k #{keychain_db.shellescape} -A -T /usr/bin/codesign -T /usr/bin/security 2>&1 || true")
      end

      sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '' #{keychain_db.shellescape} 2>&1 || true")

      id_out = sh("security find-identity -v -p codesigning #{keychain_db.shellescape} 2>&1", log: false)
      UI.message("Identities after match import: #{id_out.strip}")
      identity_found = id_out.include?("Apple Distribution") || (id_out.match(/(\d+) valid identit/) && $1.to_i > 0)

      # --- Step 2: Fallback — generate a fresh cert+key if match had no key. ---
      unless identity_found
        UI.important("No signing identity from match repo — creating fresh distribution certificate via App Store Connect API")

        cert_out_dir = Dir.mktmpdir("cert_out")
        # Note: cert on iOS does not take a `type:` argument (that's macOS-only).
        # force:true ensures a new cert+key pair is generated on this machine.
        cert(
          force:            true,
          team_id:          "D24ZU8268L",
          keychain_path:    keychain_db,
          keychain_password: "",
          api_key:          api_key,
          output_path:      cert_out_dir,
        )

        sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '' #{keychain_db.shellescape} 2>&1 || true")
        sh("echo '=== Identities after cert action ===' && security find-identity -v -p codesigning #{keychain_db.shellescape} 2>&1")

        # Export the new cert+key as a p12 and push it to the match repo so
        # future CI runs can skip this costly regeneration step.
        begin
          new_p12_plain = File.join(cert_out_dir, "export.p12")
          export_ok = system("security export -k #{keychain_db.shellescape} -t identities -f pkcs12 -P #{match_password.to_s.shellescape} #{new_p12_plain.shellescape} 2>&1")

          if export_ok && File.exist?(new_p12_plain) && File.size(new_p12_plain) > 100
            UI.message("Exported new .p12: #{File.size(new_p12_plain)} bytes")

            cer_file  = Dir.glob("#{cert_out_dir}/*.cer").first
            basename  = cer_file ? File.basename(cer_file, ".cer") : "distribution_#{Time.now.to_i}"

            # Replace old certs in the match repo
            Dir.glob("#{certs_dir}/certs/distribution/*.p12").each { |f| FileUtils.rm(f) }
            Dir.glob("#{certs_dir}/certs/distribution/*.cer").each  { |f| FileUtils.rm(f) }

            new_p12_enc = "#{certs_dir}/certs/distribution/#{basename}.p12"
            FileUtils.cp(new_p12_plain, new_p12_enc)
            enc.encrypt(file_path: new_p12_enc, password: match_password)

            if cer_file
              new_cer_enc = "#{certs_dir}/certs/distribution/#{basename}.cer"
              FileUtils.cp(cer_file, new_cer_enc)
              enc.encrypt(file_path: new_cer_enc, password: match_password)
            end

            Dir.chdir(certs_dir) do
              sh("git config user.email 'ci@gravity.app' && git config user.name 'Gravity CI'")
              sh("git add certs/ && (git diff --cached --quiet && echo 'no cert changes' || (git commit -m 'ci: regenerate distribution cert with private key' && git push 'https://#{match_user}:#{match_token}@github.com/abrekhov/gravity-certificates.git' HEAD:main)) 2>&1")
            end
            UI.success("Updated match certs repo with new certificate")
          else
            UI.important("p12 export failed or empty — match repo not updated (build may still succeed)")
          end
        rescue => e
          UI.important("Failed to update match certs repo: #{e.message}")
        end
      end

      # --- Step 3: Install provisioning profile. ---
      pp_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
      FileUtils.mkdir_p(pp_dir)

      if identity_found
        # Re-use the existing profile from the match repo (cert matched).
        encrypted_pp = Dir.glob("#{certs_dir}/profiles/appstore/*.mobileprovision").first
        if encrypted_pp
          decrypted_pp = "#{certs_dir}/profile.mobileprovision"
          FileUtils.cp(encrypted_pp, decrypted_pp)
          enc.decrypt(file_path: decrypted_pp, password: match_password)
          FileUtils.cp(decrypted_pp, "#{pp_dir}/AppStore_com.gravity.gravityGame.mobileprovision")
          UI.message("Installed provisioning profile from match (#{File.size(decrypted_pp)} bytes)")
        end
        # profile_name stays "match AppStore com.gravity.gravityGame"
      else
        # New cert was created — regenerate the provisioning profile via the API.
        sigh(
          app_identifier: "com.gravity.gravityGame",
          type:           "appstore",
          team_id:        "D24ZU8268L",
          api_key:        api_key,
          output_path:    pp_dir,
          filename:       "AppStore_com.gravity.gravityGame.mobileprovision",
        )
        profile_name = lane_context[SharedValues::SIGH_NAME]
        UI.message("Provisioning profile from sigh: #{profile_name}")

        # Push the new profile to the match repo as well.
        begin
          new_pp_path = "#{pp_dir}/AppStore_com.gravity.gravityGame.mobileprovision"
          if File.exist?(new_pp_path)
            Dir.glob("#{certs_dir}/profiles/appstore/*.mobileprovision").each { |f| FileUtils.rm(f) }
            new_pp_enc = "#{certs_dir}/profiles/appstore/AppStore_com.gravity.gravityGame.mobileprovision"
            FileUtils.cp(new_pp_path, new_pp_enc)
            enc.encrypt(file_path: new_pp_enc, password: match_password)
            Dir.chdir(certs_dir) do
              sh("git add profiles/ && (git diff --cached --quiet && echo 'no profile changes' || (git commit -m 'ci: update provisioning profile for new cert' && git push 'https://#{match_user}:#{match_token}@github.com/abrekhov/gravity-certificates.git' HEAD:main)) 2>&1")
            end
            UI.success("Updated match certs repo with new provisioning profile")
          end
        rescue => e
          UI.important("Failed to update match profile in repo: #{e.message}")
        end
      end

      # --- Step 4: Switch Runner to manual signing. ---
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id:               "D24ZU8268L",
        code_sign_identity:    "Apple Distribution",
        bundle_identifier:     "com.gravity.gravityGame",
        targets:               ["Runner"],
        path:                  "ios/Runner.xcodeproj",
        profile_name:          profile_name,
      )
    end

    # Stamp the build number from CI (github.run_number) so every push
    # produces a unique, ever-increasing build number in TestFlight.
    if ENV["BUILD_NUMBER"]
      increment_build_number(
        build_number: ENV["BUILD_NUMBER"].to_i,
        xcodeproj:    "ios/Runner.xcodeproj",
      )
    end

    build_app(
      workspace:     "ios/Runner.xcworkspace",
      scheme:        "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.gravity.gravityGame" => profile_name,
        },
      },
    )

    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Fill App Review Information notes and contact details"
  lane :set_review_notes do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    require "net/http"
    require "json"

    app = Spaceship::ConnectAPI::App.find("com.gravity.gravityGame")
    raise "App not found" unless app

    # Build JWT for raw API calls
    require "jwt"
    key_id    = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    key_pem   = ENV["ASC_API_KEY"].gsub("\\n", "\n")
    private_key = OpenSSL::PKey::EC.new(key_pem)
    payload = {
      iss: issuer_id,
      exp: Time.now.to_i + 1200,
      aud: "appstoreconnect-v1",
    }
    token = JWT.encode(payload, private_key, "ES256", { kid: key_id })

    asc = lambda do |method, path, body: nil|
      uri = URI("https://api.appstoreconnect.apple.com#{path}")
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      req_class = { get: Net::HTTP::Get, patch: Net::HTTP::Patch, post: Net::HTTP::Post }[method]
      req = req_class.new(uri)
      req["Authorization"] = "Bearer #{token}"
      req["Content-Type"]  = "application/json"
      req.body = body.to_json if body
      resp = http.request(req)
      JSON.parse(resp.body) rescue {}
    end

    # Find the edit App Store version
    edit_states = %w[PREPARE_FOR_SUBMISSION DEVELOPER_REJECTED METADATA_REJECTED REJECTED WAITING_FOR_REVIEW IN_REVIEW]
    versions = app.get_app_store_versions(filter: { platform: "IOS" })
    edit_version = versions.find { |v| edit_states.include?(v.app_store_state) }
    edit_version ||= versions.find { |v| v.app_store_state != "READY_FOR_SALE" }
    raise "No editable App Store version found" unless edit_version
    UI.message("Edit version: #{edit_version.version_string} (#{edit_version.app_store_state})")

    # Get or create the AppStoreReviewDetail
    review_resp = asc.call(:get, "/v1/appStoreVersions/#{edit_version.id}/appStoreReviewDetail")
    review_detail = review_resp.dig("data")

    notes = <<~NOTES
      PURPOSE
      Gravitas: Space Puzzles is a physics-based mobile puzzle game for iOS. Players launch a small spacecraft from a designated launch zone, using gravitational pull from planets to curve the trajectory and reach the exit gateway. The game teaches orbital mechanics concepts through 31 progressively challenging levels. No login, account, or internet connection is required to play.

      HOW TO REVIEW
      1. Launch the app — it opens directly to the main menu (no login required).
      2. Tap "CONTINUE" or "SELECT LEVEL" to enter the level picker.
      3. Tap any level from 1 to 10 to play a free level.
         - Drag from the glowing LAUNCH zone to aim, release to fire the spacecraft.
         - The goal is to reach the rotating GATEWAY portal.
         - Each level shows the number of shots remaining in the top-right corner.
         - Tap "MENU" (bottom-right) at any time to return to the main menu.
      4. Tap any level from 11 to 31 — a Premium upgrade overlay appears.
         - This overlay shows the one-time purchase price and an "UNLOCK" button.
         - Tap "UNLOCK" to trigger the StoreKit purchase flow (use a Sandbox Apple ID to test).
         - Tap outside the overlay or the close area to dismiss it without purchasing.
      5. To test the in-app purchase with Sandbox:
         - Use a Sandbox Apple ID created at appleid.apple.com.
         - No special credentials are required — the app has no user accounts.

      EXTERNAL SERVICES
      - Google AdMob: displays interstitial ads between levels for free (non-premium) users. No ads are shown to premium users or during gameplay itself.
      - Apple StoreKit / In-App Purchase: one-time non-consumable purchase "Gravitas Premium" (product ID: com.gravity.gravityGame.premium, price: $2.99 USD) that unlocks all 31 levels and removes ads permanently.

      REGIONAL DIFFERENCES
      The app functions consistently across all regions. There are no region-locked features, no region-specific content, and no regulatory restrictions. Pricing tiers follow standard App Store regional pricing.

      NO ACCOUNT REQUIRED
      The app does not require account registration, login, or any personal data. Progress is saved locally on the device using shared preferences.
    NOTES

    contact = {
      contactFirstName: "Anton",
      contactLastName:  "Brekhov",
      contactEmail:     "tony.brekhov@gmail.com",
      contactPhone:     "+31685858923",
      notes:            notes.strip,
    }

    if review_detail
      detail_id = review_detail["id"]
      UI.message("Updating existing AppStoreReviewDetail id=#{detail_id}")
      result = asc.call(:patch, "/v1/appStoreReviewDetails/#{detail_id}", body: {
        data: {
          type:       "appStoreReviewDetails",
          id:         detail_id,
          attributes: contact,
        }
      })
    else
      UI.message("Creating AppStoreReviewDetail for version #{edit_version.id}")
      result = asc.call(:post, "/v1/appStoreReviewDetails", body: {
        data: {
          type:       "appStoreReviewDetails",
          attributes: contact,
          relationships: {
            appStoreVersion: { data: { type: "appStoreVersions", id: edit_version.id } }
          }
        }
      })
    end

    if result["errors"]
      UI.error("API errors: #{result['errors'].inspect}")
    else
      UI.success("App Review Information updated successfully!")
      UI.important("REMINDER: Upload a screen recording in ASC → App Review Information → Attachment")
    end
  end

  desc "Upload App Store metadata (no binary, no screenshots)"
  lane :submit_metadata do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    # deliver has a known bug (fastlane/fastlane#20538) that crashes with "No data"
    # on first-ever App Store submissions. We bypass it with direct Spaceship API calls.

    bundle_id = "com.gravity.gravityGame"
    meta_dir  = "metadata"
    locale    = "en-US"

    name          = File.read("#{meta_dir}/#{locale}/name.txt").strip
    subtitle      = File.read("#{meta_dir}/#{locale}/subtitle.txt").strip
    description   = File.read("#{meta_dir}/#{locale}/description.txt").strip
    keywords      = File.read("#{meta_dir}/#{locale}/keywords.txt").strip
    support_url   = File.read("#{meta_dir}/#{locale}/support_url.txt").strip
    privacy_url   = File.read("#{meta_dir}/#{locale}/privacy_url.txt").strip
    release_notes = File.read("#{meta_dir}/#{locale}/release_notes.txt").strip
    primary_cat   = (File.read("#{meta_dir}/primary_category.txt").strip rescue "GAMES")
    sub_cat       = (File.read("#{meta_dir}/primary_first_sub_category.txt").strip rescue "GAMES_PUZZLE")

    # Read version string from pubspec.yaml so it stays in sync automatically.
    pubspec_version = File.read("../pubspec.yaml")[/^version:\s*(.+)/, 1].strip
    version_string  = pubspec_version.split("+").first   # e.g. "0.0.1"
    UI.message("pubspec version: #{pubspec_version}  →  App Store version: #{version_string}")

    app = Spaceship::ConnectAPI::App.find(bundle_id)
    raise "App not found: #{bundle_id}" unless app
    UI.message("Found app: #{app.id}")

    # ---- 1. App Store Version ----
    edit_states = %w[PREPARE_FOR_SUBMISSION DEVELOPER_REJECTED METADATA_REJECTED REJECTED WAITING_FOR_REVIEW IN_REVIEW]
    versions    = app.get_app_store_versions(filter: { platform: "IOS" })
    versions.each { |v| UI.message("ASC version: #{v.version_string} — #{v.app_store_state}") }
    edit_version = versions.find { |v| edit_states.include?(v.app_store_state) }
    edit_version ||= versions.find { |v| v.app_store_state != "READY_FOR_SALE" }

    if edit_version && edit_version.version_string != version_string
      UI.important("Renaming ASC version #{edit_version.version_string} → #{version_string}")
      edit_version.update(attributes: { "versionString" => version_string })
      UI.success("Version renamed")
    elsif edit_version.nil?
      UI.important("No App Store edit version — creating #{version_string}")
      Spaceship::ConnectAPI.post(
        "appStoreVersions",
        body: {
          data: {
            type: "appStoreVersions",
            attributes: { platform: "IOS", versionString: version_string, releaseType: "MANUAL" },
            relationships: { app: { data: { type: "apps", id: app.id } } },
          },
        }
      )
      sleep 10
      versions = app.get_app_store_versions(filter: { platform: "IOS" })
      edit_version = versions.find { |v| edit_states.include?(v.app_store_state) }
      raise "Failed to create App Store version" unless edit_version
      UI.success("Created version #{version_string}")
    end
    UI.message("Edit version: #{edit_version.version_string} (#{edit_version.app_store_state}) id=#{edit_version.id}")

    # ---- 2. AppStoreVersionLocalization (description, keywords, URLs, what's new) ----
    ver_locs  = edit_version.get_app_store_version_localizations
    en_ver_loc = ver_locs.find { |l| l.locale == locale }

    unless en_ver_loc
      UI.important("Creating #{locale} AppStoreVersionLocalization")
      Spaceship::ConnectAPI.post(
        "appStoreVersionLocalizations",
        body: {
          data: {
            type: "appStoreVersionLocalizations",
            attributes: { locale: locale },
            relationships: {
              appStoreVersion: { data: { type: "appStoreVersions", id: edit_version.id } },
            },
          },
        }
      )
      sleep 5
      ver_locs  = edit_version.get_app_store_version_localizations
      en_ver_loc = ver_locs.find { |l| l.locale == locale }
      raise "Failed to create #{locale} localization" unless en_ver_loc
      UI.success("Created #{locale} version localization id=#{en_ver_loc.id}")
    else
      UI.message("#{locale} version localization exists: id=#{en_ver_loc.id}")
    end

    UI.message("Patching AppStoreVersionLocalization...")
    # Note: whatsNew cannot be set on a first-ever submission (no prior live version).
    en_ver_loc.update(attributes: {
      "description"  => description,
      "keywords"     => keywords,
      "supportUrl"   => support_url,
      "marketingUrl" => privacy_url,
    })
    UI.success("Version localization updated")

    UI.message("Setting copyright...")
    edit_version.update(attributes: { "copyright" => "© 2025 Anton Brekhov" })
    UI.success("Copyright set")


    # ---- 3. AppInfo + AppInfoLocalization (name, subtitle, category, privacy URL) ----
    # app.get_app_infos is not available in all Spaceship versions; use the module function.
    begin
      app_infos = Spaceship::ConnectAPI.get_app_infos(app_id: app.id).to_models
      edit_info = app_infos.find { |i| i.app_store_state == "PREPARE_FOR_SUBMISSION" } || app_infos.first
      raise "No AppInfo found" unless edit_info
      UI.message("AppInfo id=#{edit_info.id} state=#{edit_info.app_store_state}")

      begin
        UI.message("Setting category #{primary_cat} / #{sub_cat}")
        edit_info.update_categories(
          primary_category_id:        primary_cat,
          primary_subcategory_one_id: sub_cat,
        )
        UI.success("Category set")
      rescue => ce
        UI.important("Category update skipped: #{ce.message}")
      end

      info_locs   = edit_info.get_app_info_localizations
      en_info_loc = info_locs.find { |l| l.locale == locale }

      unless en_info_loc
        UI.important("Creating #{locale} AppInfoLocalization")
        Spaceship::ConnectAPI.post(
          "appInfoLocalizations",
          body: {
            data: {
              type: "appInfoLocalizations",
              attributes: { locale: locale },
              relationships: {
                appInfo: { data: { type: "appInfos", id: edit_info.id } },
              },
            },
          }
        )
        sleep 5
        info_locs   = edit_info.get_app_info_localizations
        en_info_loc = info_locs.find { |l| l.locale == locale }
      end

      if en_info_loc
        UI.message("Patching AppInfoLocalization (name/subtitle/privacy)...")
        en_info_loc.update(attributes: {
          "name"             => name,
          "subtitle"         => subtitle,
          "privacyPolicyUrl" => privacy_url,
        })
        UI.success("App name/subtitle/privacy URL updated")
      else
        UI.important("Could not find #{locale} AppInfoLocalization — set name/subtitle manually")
      end
    rescue => e
      UI.important("AppInfo update skipped (#{e.message})")
      UI.important("Please verify in App Store Connect: name='#{name}', subtitle='#{subtitle}'")
    end

    UI.success("Metadata upload complete!")
  end

  desc "Submit latest build for App Store review"
  lane :submit_for_review do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    require "net/http"
    require "json"
    require "jwt"

    key_pem     = ENV["ASC_API_KEY"].gsub("\\n", "\n")
    private_key = OpenSSL::PKey::EC.new(key_pem)
    token = JWT.encode(
      { iss: ENV["ASC_ISSUER_ID"], exp: Time.now.to_i + 1200, aud: "appstoreconnect-v1" },
      private_key, "ES256", { kid: ENV["ASC_KEY_ID"] }
    )

    asc = lambda do |method, path, body: nil|
      uri = URI("https://api.appstoreconnect.apple.com#{path}")
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      req = { get: Net::HTTP::Get, post: Net::HTTP::Post, patch: Net::HTTP::Patch }[method].new(uri)
      req["Authorization"] = "Bearer #{token}"
      req["Content-Type"]  = "application/json"
      req.body = body.to_json if body
      JSON.parse(http.request(req).body) rescue {}
    end

    bundle_id      = "com.gravity.gravityGame"
    version_string = File.read("../pubspec.yaml")[/^version:\s*(.+)/, 1].strip.split("+").first
    UI.message("Submitting version #{version_string} for review")

    app = Spaceship::ConnectAPI::App.find(bundle_id)
    raise "App not found" unless app

    # Find or create the edit version
    versions    = app.get_app_store_versions(filter: { platform: "IOS" })
    edit_states = %w[PREPARE_FOR_SUBMISSION DEVELOPER_REJECTED METADATA_REJECTED REJECTED]
    edit_version = versions.find { |v| v.version_string == version_string && edit_states.include?(v.app_store_state) }

    unless edit_version
      UI.message("Creating App Store version #{version_string}...")
      asc.call(:post, "/v1/appStoreVersions", body: {
        data: {
          type: "appStoreVersions",
          attributes: { platform: "IOS", versionString: version_string, releaseType: "MANUAL" },
          relationships: { app: { data: { type: "apps", id: app.id } } },
        }
      })
      sleep 10
      versions     = app.get_app_store_versions(filter: { platform: "IOS" })
      edit_version = versions.find { |v| v.version_string == version_string && edit_states.include?(v.app_store_state) }
      raise "Failed to create version #{version_string}" unless edit_version
      UI.success("Created version #{version_string} (#{edit_version.id})")
    end
    UI.message("Edit version: #{edit_version.version_string} — #{edit_version.app_store_state}")

    # Attach latest valid build
    builds_resp  = asc.call(:get, "/v1/builds?filter[app]=#{app.id}&sort=-uploadedDate&limit=20")
    latest_build = (builds_resp["data"] || []).find { |b|
      b.dig("attributes", "processingState") == "VALID" &&
      b.dig("attributes", "version") == version_string
    }
    latest_build ||= (builds_resp["data"] || []).find { |b| b.dig("attributes", "processingState") == "VALID" }
    raise "No valid build found for #{version_string}" unless latest_build

    build_id  = latest_build["id"]
    build_num = latest_build.dig("attributes", "buildAudienceType") || latest_build.dig("attributes", "uploadedDate")
    UI.message("Attaching build #{build_id}...")
    asc.call(:patch, "/v1/appStoreVersions/#{edit_version.id}", body: {
      data: {
        type: "appStoreVersions",
        id:   edit_version.id,
        relationships: { build: { data: { type: "builds", id: build_id } } },
      }
    })
    UI.success("Build attached")

    # Submit for review
    UI.message("Submitting for review...")
    result = asc.call(:post, "/v1/appStoreVersionSubmissions", body: {
      data: {
        type: "appStoreVersionSubmissions",
        relationships: { appStoreVersion: { data: { type: "appStoreVersions", id: edit_version.id } } },
      }
    })

    if result["errors"]
      raise "Submission error: #{result['errors'].map { |e| e['detail'] }.join(', ')}"
    end
    UI.success("#{version_string} submitted for review!")
  end

  desc "Check App Store version status"
  lane :check_status do
    app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )
    app = Spaceship::ConnectAPI::App.find("com.gravity.gravityGame")
    versions = app.get_app_store_versions(filter: { platform: "IOS" })
    versions.each do |v|
      UI.message("Version #{v.version_string} — state: #{v.app_store_state}")
    end
  end

  lane :set_worldwide_availability do
    require 'jwt'
    require 'net/http'
    require 'json'

    key_id    = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    key_raw   = ENV["ASC_API_KEY"]

    private_key = OpenSSL::PKey::EC.new(key_raw)
    payload = {
      iss: issuer_id,
      iat: Time.now.to_i,
      exp: Time.now.to_i + 1200,
      aud: "appstoreconnect-v1"
    }
    token = JWT.encode(payload, private_key, "ES256", { kid: key_id })

    app_id = "6761319901"

    asc = lambda do |method, path, body = nil|
      uri = URI("https://api.appstoreconnect.apple.com#{path}")
      req = Net::HTTP.const_get(method).new(uri)
      req["Authorization"] = "Bearer #{token}"
      req["Content-Type"] = "application/json"
      req.body = body.to_json if body
      Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
    end

    # Fetch all territory IDs
    res_t = asc.call("Get", "/v1/territories?limit=200")
    all_territory_ids = JSON.parse(res_t.body)["data"].map { |t| t["id"] }
    UI.message("Found #{all_territory_ids.count} territories")

    # Availability ID == app_id (confirmed from previous runs)
    avail_id = app_id

    # Get currently enabled territories
    res_cur = asc.call("Get", "/v2/appAvailabilities/#{avail_id}/territoryAvailabilities?limit=200")
    UI.message("Current territories: #{res_cur.code} #{res_cur.body[0..300]}")
    current_ids = (JSON.parse(res_cur.body)["data"] || []).map do |item|
      item.dig("relationships", "territory", "data", "id")
    end.compact rescue []
    UI.message("Currently enabled: #{current_ids.count} territories")

    missing_ids = all_territory_ids - current_ids
    UI.message("Need to add: #{missing_ids.count} territories")

    # Add each missing territory via POST /v2/territoryAvailabilities
    ok = 0
    fail_count = 0
    missing_ids.each do |tid|
      r = asc.call("Post", "/v2/territoryAvailabilities", {
        data: {
          type: "territoryAvailabilities",
          attributes: { available: true },
          relationships: {
            appAvailability: { data: { type: "appAvailabilities", id: avail_id } },
            territory: { data: { type: "territories", id: tid } }
          }
        }
      })
      if r.code.to_i < 300
        ok += 1
      else
        fail_count += 1
        UI.message("  #{tid}: #{r.code} #{r.body[0..150]}") if fail_count <= 5
      end
    end

    if missing_ids.empty?
      UI.success("App already available in all #{all_territory_ids.count} territories!")
    elsif fail_count == 0
      UI.success("Added #{ok} territories — app now available worldwide!")
    else
      UI.message("Added #{ok}, failed #{fail_count} — check logs above")
    end
  end

  desc "Set age rating to 4+ (puzzle game, no mature content)"
  lane :set_age_rating do
    require 'net/http'
    require 'json'

    app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    jwt = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key:       ENV["ASC_API_KEY"],
      duration:  1200,
      in_house:  false,
    ).text

    bundle_id = "com.gravity.gravityGame"
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    raise "App not found: #{bundle_id}" unless app

    asc = ->(method, path, body: nil) do
      uri  = URI("https://api.appstoreconnect.apple.com#{path}")
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      cls  = { get: Net::HTTP::Get, post: Net::HTTP::Post, patch: Net::HTTP::Patch }[method]
      req  = cls.new(uri.to_s)
      req["Authorization"] = "Bearer #{jwt}"
      req["Content-Type"]  = "application/json"
      req.body = body.to_json if body
      resp = http.request(req)
      JSON.parse(resp.body) rescue {}
    end

    edit_states = %w[PREPARE_FOR_SUBMISSION DEVELOPER_REJECTED METADATA_REJECTED]
    versions    = app.get_app_store_versions(filter: { platform: "IOS" })
    edit_version = versions.find { |v| edit_states.include?(v.app_store_state) }
    raise "No edit version found in ASC" unless edit_version
    UI.message("Edit version: #{edit_version.version_string} (#{edit_version.id})")

    # ageRatingDeclaration lives on AppInfo, not AppStoreVersion
    app_infos = Spaceship::ConnectAPI.get_app_infos(app_id: app.id).to_models
    edit_info = app_infos.find { |i| i.app_store_state == "PREPARE_FOR_SUBMISSION" } || app_infos.first
    raise "No AppInfo found" unless edit_info
    UI.message("AppInfo id=#{edit_info.id}")

    ar_resp = asc.call(:get, "/v1/appInfos/#{edit_info.id}/ageRatingDeclaration")
    ar_id   = ar_resp.dig("data", "id")
    raise "ageRatingDeclaration not found: #{ar_resp.inspect}" unless ar_id
    UI.message("ageRatingDeclaration id=#{ar_id}")

    result = asc.call(:patch, "/v1/ageRatingDeclarations/#{ar_id}", body: {
      data: {
        type: "ageRatingDeclarations",
        id:   ar_id,
        attributes: {
          alcoholTobaccoOrDrugUseOrReferences:         "NONE",
          contests:                                     "NONE",
          gambling:                                     false,
          horrorOrFearThemes:                           "NONE",
          matureOrSuggestiveThemes:                     "NONE",
          medicalOrTreatmentInformation:               "NONE",
          profanityOrCrudeHumor:                        "NONE",
          sexualContentGraphicAndNudity:                "NONE",
          sexualContentOrNudity:                        "NONE",
          unrestrictedWebAccess:                        false,
          violenceCartoonOrFantasy:                     "NONE",
          violenceRealistic:                            "NONE",
          violenceRealisticProlongedGraphicOrSadistic:  "NONE",
        },
      },
    })

    if result["errors"]
      raise "Age rating update failed: #{result['errors'].map { |e| e['detail'] }.join(', ')}"
    end
    UI.success("Age rating set → 4+ (all categories NONE / false)")
  end

  desc "Attach latest valid TestFlight build to the App Store edit version"
  lane :attach_build do
    require 'net/http'
    require 'json'

    app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    jwt = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key:       ENV["ASC_API_KEY"],
      duration:  1200,
      in_house:  false,
    ).text

    bundle_id = "com.gravity.gravityGame"
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    raise "App not found: #{bundle_id}" unless app

    asc = ->(method, path, body: nil) do
      uri  = URI("https://api.appstoreconnect.apple.com#{path}")
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      cls  = { get: Net::HTTP::Get, post: Net::HTTP::Post, patch: Net::HTTP::Patch }[method]
      req  = cls.new(uri.to_s)
      req["Authorization"] = "Bearer #{jwt}"
      req["Content-Type"]  = "application/json"
      req.body = body.to_json if body
      resp = http.request(req)
      JSON.parse(resp.body) rescue {}
    end

    # Find the latest valid iOS build via raw API
    builds_resp = asc.call(:get, "/v1/builds?filter[app]=#{app.id}&sort=-uploadedDate&limit=20")
    all_builds  = builds_resp["data"] || []
    UI.message("Total builds fetched: #{all_builds.size}")
    if all_builds.first
      sample = all_builds.first["attributes"] || {}
      UI.message("Sample build attrs: processingState=#{sample['processingState']} platform=#{sample['platform']} minOsVersion=#{sample['minOsVersion']}")
    end
    latest_build = all_builds.find do |b|
      b.dig("attributes", "processingState") == "VALID" &&
      b.dig("attributes", "platform") == "IOS"
    end
    # Fallback: any VALID build if platform key is absent/different
    latest_build ||= all_builds.find { |b| b.dig("attributes", "processingState") == "VALID" }
    raise "No valid iOS builds found in TestFlight (#{all_builds.size} total, states: #{all_builds.map { |b| b.dig('attributes','processingState') }.uniq.join(',')}, platforms: #{all_builds.map { |b| b.dig('attributes','platform') }.uniq.join(',')})" unless latest_build
    latest_build_id      = latest_build["id"]
    latest_build_version = latest_build.dig("attributes", "version")
    UI.message("Latest build: version=#{latest_build_version} id=#{latest_build_id}")

    # Find the edit version (include REJECTED — Apple sets this state after info requests)
    edit_states  = %w[PREPARE_FOR_SUBMISSION DEVELOPER_REJECTED METADATA_REJECTED REJECTED WAITING_FOR_REVIEW IN_REVIEW]
    versions     = app.get_app_store_versions(filter: { platform: "IOS" })
    versions.each { |v| UI.message("ASC version: #{v.version_string} — #{v.app_store_state}") }
    edit_version = versions.find { |v| edit_states.include?(v.app_store_state) }
    edit_version ||= versions.find { |v| v.app_store_state != "READY_FOR_SALE" }
    raise "No edit version found in ASC" unless edit_version
    UI.message("Edit version: #{edit_version.version_string} (#{edit_version.id})")

    result = asc.call(:patch, "/v1/appStoreVersions/#{edit_version.id}", body: {
      data: {
        type: "appStoreVersions",
        id:   edit_version.id,
        relationships: {
          build: { data: { type: "builds", id: latest_build_id } },
        },
      },
    })

    if result["errors"]
      raise "Attach build failed: #{result['errors'].map { |e| e['detail'] }.join(', ')}"
    end
    UI.success("Build #{latest_build_version} attached to App Store version #{edit_version.version_string}")
  end

  desc "Create Premium non-consumable IAP in App Store Connect"
  lane :setup_iap do
    require 'net/http'
    require 'json'

    app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY"],
    )

    # Build JWT for direct v1/v2 HTTP calls (Spaceship only exposes v1 via module functions)
    jwt = Spaceship::ConnectAPI::Token.create(
      key_id:    ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key:       ENV["ASC_API_KEY"],
      duration:  1200,
      in_house:  false,
    ).text

    bundle_id   = "com.gravity.gravityGame"
    product_id  = "com.gravity.gravityGame.premium"
    price_usd   = "2.99"
    locale      = "en-US"
    iap_name    = "Gravitas Premium"
    iap_desc    = "Unlock all 31 levels and remove ads forever"
    review_note = "Tap any locked level (11-31) on the level select screen to trigger the Premium offer sheet."

    app = Spaceship::ConnectAPI::App.find(bundle_id)
    raise "App not found: #{bundle_id}" unless app
    UI.message("App: #{app.id}")

    # Raw HTTP helper — supports any ASC API version
    asc = ->(method, path, body: nil) do
      uri  = URI("https://api.appstoreconnect.apple.com#{path}")
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      cls  = { get: Net::HTTP::Get, post: Net::HTTP::Post, patch: Net::HTTP::Patch }[method]
      req  = cls.new(uri.to_s)
      req["Authorization"] = "Bearer #{jwt}"
      req["Content-Type"]  = "application/json"
      req.body = body.to_json if body
      resp = http.request(req)
      JSON.parse(resp.body) rescue {}
    end

    # ---- 1. Find or create IAP ----
    # Tries multiple endpoints because the relationship endpoints sometimes return
    # 0 results even when an IAP exists (state filtering / pagination quirks).
    find_iap = lambda do
      # 1a. v2 relationship endpoint
      resp = asc.call(:get, "/v2/apps/#{app.id}/inAppPurchasesV2?limit=200")
      items = resp["data"] || []
      UI.message("v2 relationship: #{items.size} item(s) | errors=#{resp['errors']&.map { |e| e['detail'] }&.inspect}")
      match = items.find { |i| i.dig("attributes", "productId") == product_id }
      return match["id"] if match

      # 1b. v1 relationship endpoint
      resp2 = asc.call(:get, "/v1/apps/#{app.id}/inAppPurchases?limit=200")
      items2 = resp2["data"] || []
      UI.message("v1 relationship: #{items2.size} item(s) | product IDs: #{items2.map { |i| i.dig('attributes','productId') }.join(', ')}")
      match2 = items2.find { |i| i.dig("attributes", "productId") == product_id }
      return match2["id"] if match2

      # 1c. v1 top-level collection filtered by app (different query path from relationship)
      resp3 = asc.call(:get, "/v1/inAppPurchases?filter[app]=#{app.id}&limit=200")
      items3 = resp3["data"] || []
      UI.message("v1 top-level: #{items3.size} item(s) | product IDs: #{items3.map { |i| i.dig('attributes','productId') }.join(', ')}")
      match3 = items3.find { |i| i.dig("attributes", "productId") == product_id }
      return match3["id"] if match3

      nil
    end

    iap_id          = find_iap.call
    iap_just_created = false

    if iap_id
      UI.message("IAP already exists: #{iap_id}")
    else
      UI.message("Creating IAP #{product_id}...")
      resp   = asc.call(:post, "/v2/inAppPurchases", body: {
        data: {
          type: "inAppPurchases",
          attributes: {
            productId:         product_id,
            inAppPurchaseType: "NON_CONSUMABLE",
            name:              iap_name,
          },
          relationships: {
            app: { data: { type: "apps", id: app.id } },
          },
        },
      })
      iap_id = resp.dig("data", "id")

      unless iap_id
        err = resp.dig("errors", 0, "detail") || ""
        err_title = resp.dig("errors", 0, "title") || ""
        UI.message("Create response (no id): #{resp.to_json[0..800]}")

        if err.include?("already") || err_title.include?("already") ||
           err.include?("duplicate") || err_title.include?("duplicate") ||
           err.include?("being used") || err_title.include?("being used")
          UI.important("Duplicate detected — re-fetching IAP list...")
          iap_id = find_iap.call
          raise "Could not find existing IAP after duplicate error.\nFull create response: #{resp.to_json}" unless iap_id
          UI.message("Found existing IAP: #{iap_id}")
        else
          raise "Failed to create IAP: #{err.empty? ? resp.inspect : "#{err_title} — #{err}"}"
        end
      else
        UI.success("Created IAP: #{iap_id}")
        iap_just_created = true
        # Set reviewNote via PATCH (not accepted in the CREATE body)
        asc.call(:patch, "/v2/inAppPurchases/#{iap_id}", body: {
          data: { type: "inAppPurchases", id: iap_id,
                  attributes: { reviewNote: review_note } },
        })
        UI.success("Review note set")
        sleep 2
      end
    end

    # ---- 2. English localization (name + description) ----
    loc_resp = asc.call(:get, "/v1/inAppPurchaseLocalizations?filter[inAppPurchaseV2]=#{iap_id}&filter[locale]=#{locale}")
    if loc_resp.dig("data", 0)
      UI.message("#{locale} localization already exists")
    else
      UI.message("Adding #{locale} localization...")
      asc.call(:post, "/v1/inAppPurchaseLocalizations", body: {
        data: {
          type: "inAppPurchaseLocalizations",
          attributes: {
            locale:      locale,
            name:        iap_name,
            description: iap_desc,
          },
          relationships: {
            inAppPurchaseV2: { data: { type: "inAppPurchases", id: iap_id } },
          },
        },
      })
      UI.success("#{locale} localization added")
    end

    # ---- 3. Pricing — $2.99 base in USD, Apple auto-converts all territories ----
    # v1 and v2 use different ID formats for the same IAP resource.
    # When iap_id came from the v1 list (UUID), the v2 pricePoints endpoint won't return
    # data for it — but the price was already set in a prior run. Skip gracefully.
    pp_resp   = asc.call(:get, "/v2/inAppPurchases/#{iap_id}/pricePoints?filter[territory]=USA")
    price_pts = pp_resp["data"] || []
    target_pp = price_pts.find { |pp| pp.dig("attributes", "customerPrice") == price_usd }

    if target_pp.nil? && !iap_just_created
      UI.important("Price points unavailable for existing IAP (v1/v2 ID mismatch) — price was set in a prior run, skipping")
    elsif target_pp.nil?
      raise "Price point $#{price_usd} not found. Available: #{price_pts.map { |pp| pp.dig('attributes', 'customerPrice') }.compact.sort.first(8).join(', ')}"
    else
      UI.message("Price point $#{price_usd} → id=#{target_pp['id']}")

    sched_resp = asc.call(:post, "/v1/inAppPurchasePriceSchedules", body: {
      data: {
        type: "inAppPurchasePriceSchedules",
        relationships: {
          inAppPurchase: { data: { type: "inAppPurchases", id: iap_id } },
          baseTerritory: { data: { type: "territories",   id: "USA"  } },
          manualPrices:  { data: [{ type: "inAppPurchasePrices", id: "${p1}" }] },
        },
      },
      included: [
        {
          id:   "${p1}",
          type: "inAppPurchasePrices",
          attributes: { startDate: nil },
          relationships: {
            inAppPurchasePricePoint: { data: { type: "inAppPurchasePricePoints", id: target_pp["id"] } },
            territory:               { data: { type: "territories",              id: "USA"            } },
          },
        },
      ],
    })

    if sched_resp.dig("errors")
      detail = sched_resp["errors"].map { |e| e["detail"] }.join(", ")
      # "price schedule already exists" on a re-run is not a real error
      UI.important("Pricing note: #{detail}")
    else
      UI.success("Price set to $#{price_usd} (Apple auto-converts all other territories)")
    end
    end  # closes the target_pp else branch

    UI.success("IAP setup complete!")
    UI.success("Product ID : #{product_id}")
    UI.important("Still needed: upload a paywall screenshot in ASC → your app → IAP → #{iap_name} → Review Information")
  end
end
